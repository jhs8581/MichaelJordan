# ────────────────────────────────────────────────────────────
# MSSQL 연결 문자열 (Prisma sqlserver 형식)
# 서버명, DB명, 계정 정보를 실제 값으로 변경하세요.
# ────────────────────────────────────────────────────────────
DATABASE_URL="sqlserver://YOUR_SERVER:1433;database=ChatDB;user=YOUR_USER;password=YOUR_PASSWORD;encrypt=true;trustServerCertificate=true"

# ────────────────────────────────────────────────────────────
# JWT 서명 키 (최소 32자 이상의 랜덤 문자열 사용)
# 랜덤 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ────────────────────────────────────────────────────────────
JWT_SECRET=changeme-replace-with-random-256bit-key-here

# ────────────────────────────────────────────────────────────
# 서버 설정
# ────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ────────────────────────────────────────────────────────────
# CORS 허용 출처 (Vercel 도메인 또는 로컬 개발 주소)
# ────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
