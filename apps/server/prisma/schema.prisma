generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model User {
  id                Int                @id @default(autoincrement())
  email             String             @unique @db.NVarChar(255)
  username          String             @unique @db.NVarChar(50)
  passwordHash      String             @db.NVarChar(255)
  avatarUrl         String?            @db.NVarChar(500)
  isOnline          Boolean            @default(false)
  lastSeenAt        DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @default(now())
  chatLockCode      String             @default("") @db.NVarChar(32)
  timeZone          String?            @db.NVarChar(100)
  chatTheme         String             @default("slr") @db.NVarChar(20)
  comments          Comment[]          @relation("AuthoredComments")
  sentMessages      Message[]          @relation("SentMessages")
  messageReads      MessageRead[]
  posts             Post[]             @relation("AuthoredPosts")
  pushSubscriptions PushSubscription[]
  refreshTokens     RefreshToken[]
  roomMembers       RoomMember[]
  createdSchedules  Schedule[]
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique @db.NVarChar(500)
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Room {
  id        Int          @id @default(autoincrement())
  name      String       @db.NVarChar(100)
  isGroup   Boolean      @default(false)
  createdAt DateTime     @default(now())
  isArchive Boolean      @default(false)
  roomTimeZone1 String?  @db.NVarChar(100)
  roomTimeZone2 String?  @db.NVarChar(100)
  messages  Message[]
  posts     Post[]
  members   RoomMember[]
  schedules Schedule[]
}

model RoomMember {
  userId   Int
  roomId   Int
  joinedAt DateTime @default(now())
  isMuted  Boolean  @default(false)
  room     Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roomId])
}

model Message {
  id              Int           @id @default(autoincrement())
  roomId          Int
  senderId        Int
  content         String        @db.NVarChar(Max)
  fileUrl         String?       @db.NVarChar(500)
  createdAt       DateTime      @default(now())
  senderTimeZone  String?       @db.NVarChar(100)
  senderLocalTime String?       @db.NVarChar(16)
  replyToId       Int?
  replyTo         Message?      @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies         Message[]     @relation("MessageReplies")
  room            Room          @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender          User          @relation("SentMessages", fields: [senderId], references: [id])
  reads           MessageRead[]
  posts           Post[]        @relation("PostSourceMessage")
}

model MessageRead {
  messageId Int
  userId    Int
  readAt    DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onUpdate: NoAction)

  @@id([messageId, userId])
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  userId    Int
  endpoint  String   @db.NVarChar(Max)
  p256dh    String   @db.NVarChar(Max)
  auth      String   @db.NVarChar(Max)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Schedule {
  id          Int      @id @default(autoincrement())
  roomId      Int
  title       String   @db.NVarChar(200)
  description String?  @db.NVarChar(Max)
  scheduledAt DateTime
  isAllDay    Boolean  @default(false)
  notified    Boolean  @default(false)
  createdById Int
  createdAt   DateTime @default(now())
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  createdBy   User     @relation(fields: [createdById], references: [id])
}

model Post {
  id              Int      @id @default(autoincrement())
  roomId          Int
  title           String   @db.NVarChar(500)
  content         String   @db.NVarChar(Max)
  authorId        Int
  sourceMessageId Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now())
  author          User     @relation("AuthoredPosts", fields: [authorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sourceMessage   Message? @relation("PostSourceMessage", fields: [sourceMessageId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  room            Room     @relation(fields: [roomId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  comments        Comment[]
}

model Comment {
  id        Int      @id @default(autoincrement())
  postId    Int
  content   String   @db.NVarChar(Max)
  authorId  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  author    User     @relation("AuthoredComments", fields: [authorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}
